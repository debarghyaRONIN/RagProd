# ==============================================================================
# RAG QA System — Environment Variables Template
# Copy this file to '.env' and populate with your credentials.
# ==============================================================================

# Application Security
# Cryptographically secure random 32-byte key for JWT signing. Generate via: openssl rand -hex 32
SECRET_KEY=change-me-to-a-secure-32-char-random-string

# PostgreSQL Configuration
POSTGRES_PASSWORD=strongpassword

# MinIO Object Storage Configuration (used by Milvus Standalone)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# HuggingFace Hub Token
# Optional: Only required for gated models (like Llama-3/Mistral-7B). Leave empty for Qwen.
HF_TOKEN=

# RunPod Infrastructure (for Terraform deployment)
# Required for running terraform scripts
RUNPOD_API_KEY=
